{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hydrogen-storefront",
  "compatibility_date": "2025-03-10",
  "main": "./workers/app.ts",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./build/client"
  }
}
