{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/server",
  "framework": null,
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/dist/client/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/server/index.js"
    }
  ],
  "functions": {
    "dist/server/index.js": {
      "runtime": "nodejs18.x"
    }
  }
}
